APP_NAME="AI Receptionist MVP"
APP_ENV=local
LOG_LEVEL=INFO
DATABASE_PATH=data/leads.db

# Optional for local smoke tests. Add this only when you want real OpenAI responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional until you connect real provider webhooks.
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Optional until you connect Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional until you want real calendar booking.
GOOGLE_CALENDAR_ID=
GOOGLE_APPLICATION_CREDENTIALS=
ESTIMATE_DURATION_MINUTES=60
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=17

# Optional owner email notifications. If blank, notifications are logged only.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
OWNER_EMAIL=

BUSINESS_TIMEZONE=America/New_York
BUSINESS_NAME="Example Business"
BUSINESS_PHONE="+15555550100"
